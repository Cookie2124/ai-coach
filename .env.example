# AiCoach Environment Configuration
# Copy to .env and fill in your values

# Server
PORT=3001
JWT_SECRET=change-this-to-a-random-secret
APP_URL=http://localhost:3001
CLIENT_URL=http://localhost:5173
# Optional: set only if you need a fixed callback URL regardless of how you open the app
# OAUTH_REDIRECT_URI=http://100.96.108.122:3001/api/integrations/oauth/callback
#
# Phone/Tailscale access: open http://YOUR-IP:5173 — OAuth callback auto-uses port 3001.
# Register BOTH in WHOOP if you use desktop + phone:
#   http://localhost:3001/api/integrations/oauth/callback
#   http://100.96.108.122:3001/api/integrations/oauth/callback

# OpenRouter AI (https://openrouter.ai)
OPENROUTER_API_KEY=your-openrouter-api-key
# Preferred model — requires credits at https://openrouter.ai/settings/credits
# Free fallbacks are used automatically if credits are unavailable
OPENROUTER_MODEL=openai/gpt-5.6-luna

# WHOOP OAuth (https://developer.whoop.com)
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=

# Google OAuth — one connection for Calendar + Gmail
# Google Cloud does NOT allow IP addresses (100.x.x.x) as redirect URIs — use localhost only:
#   http://localhost:3001/api/integrations/oauth/callback
#   http://127.0.0.1:3001/api/integrations/oauth/callback
# Connect Google via localhost on the Pi, or SSH tunnel from your PC (see Integrations page).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth (Outlook Calendar + Email)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Strava OAuth
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Garmin OAuth
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=
