# AiCoach Environment Configuration
# Copy to .env and fill in your values

# Server
PORT=3001
JWT_SECRET=change-this-to-a-random-secret

# Local development
# APP_URL=http://localhost:3001
# CLIENT_URL=http://localhost:5173

# Raspberry Pi + Tailscale HTTPS (recommended for phone access + OAuth)
APP_URL=https://pi.tailfa75f0.ts.net:3001
CLIENT_URL=https://pi.tailfa75f0.ts.net:3001
#
# Setup Tailscale HTTPS on the Pi:
#   chmod +x scripts/setup-tailscale-https.sh
#   ./scripts/setup-tailscale-https.sh
#
# Register this OAuth redirect URI in WHOOP + Google Cloud:
#   https://pi.tailfa75f0.ts.net:3001/api/integrations/oauth/callback

# Optional: force a fixed OAuth callback regardless of browser origin
# OAUTH_REDIRECT_URI=https://pi.tailfa75f0.ts.net:3001/api/integrations/oauth/callback

# OpenRouter AI (https://openrouter.ai)
OPENROUTER_API_KEY=your-openrouter-api-key
# Preferred model — requires credits at https://openrouter.ai/settings/credits
# Free fallbacks are used automatically if credits are unavailable
OPENROUTER_MODEL=openai/gpt-5.6-luna

# WHOOP OAuth (https://developer.whoop.com)
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=

# Google OAuth — one connection for Calendar + Gmail
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth (Outlook Calendar + Email)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Strava OAuth
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Garmin OAuth
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=
